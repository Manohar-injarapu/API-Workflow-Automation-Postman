    {
      "name": "update_user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "// Test 1: Response status is 200",
              "pm.test(\"Response status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test 2: Response body contains 'name' field and it is a string",
              "pm.test(\"Response body contains 'name' field and it is a string\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"name\");",
              "    pm.expect(jsonData.name).to.be.a(\"string\");",
              "});",
              "",
              "// Test 3: Response body contains 'job' field and it is a string",
              "pm.test(\"Response body contains 'job' field and it is a string\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"job\");",
              "    pm.expect(jsonData.job).to.be.a(\"string\");",
              "});",
              "",
              "// Test 4: Response body contains 'updatedAt' field and it is a string",
              "pm.test(\"Response body contains 'updatedAt' field and it is a string\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"updatedAt\");",
              "    pm.expect(jsonData.updatedAt).to.be.a(\"string\");",
              "});",
              "",
              "// Test 5: Response time is less than 3000ms",
              "pm.test(\"Response time is less than 3000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              ""
